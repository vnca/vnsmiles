---
/* admin.astro - Giao diện quản trị Sveltia CMS đã được TỐI ƯU RESPONSIVE */
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Trang quản trị Blog - VnSmiles</title>
  <script src="https://unpkg.com/@sveltia/cms@0.41.0/dist/sveltia-cms.js"></script>
  
  <style is:global>
    /* Tối ưu hóa vùng chứa trên thiết bị di động */
    body {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }
    
    /* Khi màn hình nhỏ hơn 768px (Điện thoại và máy tính bảng nhỏ) */
    @media (max-width: 768px) {
      /* Ép các khu vực chính chuyển thành một cột dọc */
      div[class*="AppLayout"], div[class*="MainLayout"] {
        flex-direction: column !important;
        display: block !important;
      }
      
      /* Thu gọn sidebar menu trái thành thanh cuộn ngang hoặc đẩy xuống dưới */
      aside, div[class*="Sidebar"] {
        width: 100% !important;
        max-width: 100% !important;
        position: relative !important;
        height: auto !important;
        box-shadow: none !important;
        border-bottom: 1px solid #e5e7eb;
      }
      
      /* Phóng to các ô nhập liệu để dễ bấm bằng tay trên điện thoại */
      input, textarea, select, .w-md-editor {
        font-size: 16px !important; /* Tránh iOS tự động zoom màn hình khi focus vào ô nhập */
        padding: 12px !important;
      }
      
      /* Khu vực danh sách bài viết hiển thị full chiều ngang */
      main, div[class*="CollectionVisualizer"], div[class*="EditorContainer"] {
        padding: 10px !important;
        width: 100% !important;
        box-sizing: border-box !important;
      }

      /* Chuyển các hàng nút bấm hành động (Publish, Save) thành hàng ngang cố định hoặc xếp dọc */
      div[class*="Toolbar"] {
        padding: 8px !important;
        gap: 8px !important;
      }
      
      /* Tối ưu bảng danh sách bài viết trên mobile thành dạng thẻ (card) cuộn dọc */
      table {
        display: block !important;
        overflow-x: auto !important;
        white-space: nowrap !important;
      }
    }
  </style>
</head>
<body>
  <script is:inline>
    window.CMS_MANUAL_INIT = true;
    
    document.addEventListener("DOMContentLoaded", () => {
      window.CMS.init({
        config: {
          backend: {
            name: 'github',
            repo: 'vnca/vnsmiles',
            branch: 'main',
            base_url: 'https://vnsmiles-cms-oauth.vna.workers.dev',
            clear_hash: true
          },
          load_config_file: false,
          media_folder: 'public/images/uploads',
          public_folder: '/public/images/uploads',
          collections: [
            {
              name: 'blog',
              label: 'Bài viết Blog',
              folder: 'src/content/blog',
              create: true,
              slug: '{{slug}}',
              fields: [
                { label: 'Tiêu đề', name: 'title', widget: 'string' },
                { label: 'Ngày đăng', name: 'pubDate', widget: 'datetime', format: 'YYYY-MM-DDTHH:mm:ssZ' },
                { label: 'Ảnh đại diện bài viết (Featured Image)', name: 'heroImage', widget: 'image', required: false },
                { label: 'Mô tả ngắn', name: 'description', widget: 'string' },
                { label: 'Nội dung bài viết', name: 'body', widget: 'markdown' }
              ]
            }
          ]
        }
      });
    });
  </script>
</body>
</html>
