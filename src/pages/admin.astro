---
/* admin.astro - Giao diện quản trị Sveltia CMS tối ưu Responsive HOÀN HẢO trên Mobile */
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Trang quản trị Blog - VnSmiles</title>
  <script src="https://unpkg.com/@sveltia/cms@0.41.0/dist/sveltia-cms.js"></script>
  
  <style is:global>
    body {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }
    
    /* Ép responsive mạnh mẽ hơn khi xem trên điện thoại (< 768px) */
    @media (max-width: 768px) {
      /* Khối chính bọc toàn bộ ứng dụng */
      div[class*="app-layout"], div[class*="AppLayout"], .app-container {
        flex-direction: column !important;
        display: block !important;
      }
      
      /* Xử lý riêng cho cột Menu bên trái đang chiếm diện tích */
      aside, 
      div[class*="sidebar"], 
      div[class*="Sidebar"],
      div[role="navigation"] {
        width: 100% !important;
        max-width: 100% !important;
        min-width: 100% !important;
        position: relative !important;
        height: auto !important;
        box-shadow: none !important;
        border-bottom: 1px solid #e5e7eb;
        padding: 8px !important;
        box-sizing: border-box !important;
      }
      
      /* Thu gọn danh sách menu con bên trong thành hàng ngang thay vì xếp dọc */
      aside ul, div[class*="Sidebar"] ul {
        display: flex !important;
        flex-direction: row !important;
        gap: 8px !important;
        padding: 0 !important;
        margin: 0 !important;
        overflow-x: auto;
      }

      /* Khu vực hiển thị danh sách bài viết bên phải */
      main, 
      div[class*="main-content"], 
      div[class*="CollectionVisualizer"], 
      div[class*="EditorContainer"] {
        width: 100% !important;
        max-width: 100% !important;
        padding: 12px !important;
        box-sizing: border-box !important;
        display: block !important;
      }

      /* Ép các dòng bài viết hiển thị rộng rãi, không bị nén chữ */
      div[class*="row"], tr, [role="row"] {
        width: 100% !important;
      }
      
      /* Giúp chữ tiêu đề hiển thị đầy đủ, tự động xuống dòng nếu quá dài */
      span[class*="title"], div[class*="label"], .primary-text {
        white-space: normal !important;
        word-break: break-word !important;
      }

      /* Cải thiện ô nhập liệu tránh tự động zoom trên màn hình iOS */
      input, textarea, select {
        font-size: 16px !important;
      }
    }
  </style>
</head>
<body>
  <script is:inline>
    window.CMS_MANUAL_INIT = true;
    
    document.addEventListener("DOMContentLoaded", () => {
      window.CMS.init({
        config: {
          backend: {
            name: 'github',
            repo: 'vnca/vnsmiles',
            branch: 'main',
            base_url: 'https://vnsmiles-cms-oauth.vna.workers.dev',
            clear_hash: true
          },
          load_config_file: false,
          media_folder: 'public/images/uploads',
          public_folder: '/public/images/uploads',
          collections: [
            {
              name: 'blog',
              label: 'Bài viết Blog',
              folder: 'src/content/blog',
              create: true,
              slug: '{{slug}}',
              fields: [
                { label: 'Tiêu đề', name: 'title', widget: 'string' },
                { label: 'Ngày đăng', name: 'pubDate', widget: 'datetime', format: 'YYYY-MM-DDTHH:mm:ssZ' },
                { label: 'Ảnh đại diện bài viết (Featured Image)', name: 'heroImage', widget: 'image', required: false },
                { label: 'Mô tả ngắn', name: 'description', widget: 'string' },
                { label: 'Nội dung bài viết', name: 'body', widget: 'markdown' }
              ]
            }
          ]
        }
      });
    });
  </script>
</body>
</html>
