cat << 'EOF' > src/pages/admin.astro
---
/* admin.astro - Giao diện quản trị viết bài bằng Sveltia CMS */
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trang quản trị Blog - VnSmiles</title>
  <!-- Nhúng thư viện Sveltia CMS hiện đại, tương thích 100% với Cloudflare Pages -->
  <script src="https://unpkg.com/@sveltia/cms@0.41.0/dist/sveltia-cms.js"></script>
</head>
<body>
  <script is:inline>
    window.CMS_MANUAL_INIT = true;
    
    document.addEventListener("DOMContentLoaded", () => {
      window.CMS.init({
        config: {
          backend: {
            name: 'github',
            repo: 'vnca/vnsmiles',
            branch: 'main',
            base_url: 'https://vnsmiles-cms-oauth.vna.workers.dev', // Giữ nguyên Worker của bạn
            clear_hash: true
          },
          load_config_file: false,
          media_folder: 'public/images/uploads',
          public_folder: '/images/uploads',
          collections: [
            {
              name: 'blog',
              label: 'Bài viết Blog',
              folder: 'src/content/blog',
              create: true,
              slug: '{{slug}}',
              fields: [
                { label: 'Tiêu đề', name: 'title', widget: 'string' },
                { label: 'Ngày đăng', name: 'date', widget: 'datetime' },
                { label: 'Mô tả ngắn', name: 'description', widget: 'string' },
                { label: 'Nội dung bài viết', name: 'body', widget: 'markdown' }
              ]
            }
          ]
        }
      });
    });
  </script>
</body>
</html>
EOF
